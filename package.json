{
  "name": "kavach-server",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "NODE_OPTIONS='--experimental-sqlite' tsx watch --env-file=.env server/index.ts",
    "build": "tsc -p tsconfig.server.json",
    "lint": "eslint .",
    "test": "tsx --test tests/server/**/*.test.ts",
    "demo:reset": "tsx server/reset-demo.ts",
    "start": "node --env-file=.env server/dist/server/index.js"
  },
  "dependencies": {
    "@faker-js/faker": "^8.4.1",
    "@google-cloud/firestore": "^7.11.0",
    "@vercel/analytics": "^2.0.1",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.2.0",
    "mongodb": "^6.21.0",
    "morgan": "^1.10.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.3",
    "@types/morgan": "^1.9.9",
    "@types/node": "^24.12.0",
    "eslint": "^9.39.4",
    "globals": "^17.4.0",
    "tsx": "^4.20.6",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0"
  }
}
