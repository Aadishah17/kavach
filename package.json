{
  "name": "kavach-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n client,server -c cyan,yellow \"npm:dev:client\" \"npm:dev:server\"",
    "dev:client": "vite",
    "dev:server": "tsx watch server/index.ts",
    "build": "npm run build:client && npm run build:server",
    "build:client": "tsc -b tsconfig.app.json tsconfig.node.json && vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "lint": "eslint .",
    "test": "npm run test:server && npm run test:web",
    "test:server": "tsx --test tests/server/**/*.test.ts",
    "test:web": "vitest run",
    "demo:reset": "tsx server/reset-demo.ts",
    "preview": "vite preview",
    "start": "node server/dist/server/index.js"
  },
  "dependencies": {
    "@google-cloud/firestore": "^7.11.0",
    "@headlessui/react": "^2.0.0",
    "@vercel/analytics": "^2.0.1",
    "@faker-js/faker": "^8.4.1",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "clsx": "^2.1.0",
    "express": "^5.1.0",
    "express-rate-limit": "^7.2.0",
    "framer-motion": "^11.0.0",
    "helmet": "^7.1.0",
    "lucide-react": "^0.350.0",
    "morgan": "^1.10.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.0",
    "recharts": "^2.12.0",
    "scheduler": "^0.23.2",
    "tailwind-merge": "^2.2.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@remix-run/router": "^1.15.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.3",
    "@types/morgan": "^1.9.9",
    "@types/node": "^24.12.0",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^29.0.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.20.6",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "vitest": "^4.1.0"
  }
}
